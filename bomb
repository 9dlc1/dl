        <button id="fireBtn">发射</button>
        <button id="resetBtn">重置</button>
      </div>
    </header>

    <section class="stage-wrap">
      <canvas id="canvas"></canvas>

      <div class="hud">
        水平速度：<b id="vxText">0</b> px/s<br>
        竖直速度：<b id="vyText">0</b> px/s<br>
        反弹次数：<b id="bounceText">0</b><br>
        状态：<span id="statusText" class="status">待发射</span>
      </div>

      <div class="hint">调整参数后点击“发射”；停止后会自动重置</div>
    </section>
  </main>

<script>
(() => {
  const canvas = document.getElementById('canvas');
  const ctx = canvas.getContext('2d');

  const angleInput = document.getElementById('angle');
  const speedInput = document.getElementById('speed');
  const angleValue = document.getElementById('angleValue');
  const speedValue = document.getElementById('speedValue');
  const fireBtn = document.getElementById('fireBtn');
  const resetBtn = document.getElementById('resetBtn');

  const vxText = document.getElementById('vxText');
  const vyText = document.getElementById('vyText');
  const bounceText = document.getElementById('bounceText');
  const statusText = document.getElementById('statusText');

  const physics = {
    gravity: 920,          // 重力加速度 px/s²
    airDrag: 0.035,        // 空气阻力系数（速度缓慢衰减）
    restitution: 0.66,     // 反弹恢复系数
    groundFriction: 0.80,  // 每次撞地时水平速度损失
    rollingFriction: 210,  // 滚动摩擦减速度 px/s²
    stopSpeed: 7,          // 低于此速度视为停止
    bounceThreshold: 70    // 竖直撞击速度太小时进入滚动
  };

  let W = 1000;
  let H = 620;
  let dpr = 1;
  let groundY = 0;

  const cannon = {
    x: 100,
    y: 0,
    barrelLength: 100,
    barrelWidth: 24
  };

  const ball = {
    x: 0,
    y: 0,
    vx: 0,
    vy: 0,
    r: 12,
    angle: 0
  };

  let mode = 'idle'; // idle, flying, rolling, stopped
  let bounceCount = 0;
  let lastTime = performance.now();
  let stoppedAt = 0;
  let muzzleFlash = 0;
  let smoke = [];
  let trail = [];

  function resize() {
    const rect = canvas.getBoundingClientRect();
    dpr = Math.min(window.devicePixelRatio || 1, 2);

    canvas.width = Math.round(rect.width * dpr);
    canvas.height = Math.round(rect.height * dpr);

    W = rect.width;
    H = rect.height;
    groundY = H * 0.78;
    cannon.y = groundY - 27;

    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    if (mode === 'idle') placeBallAtMuzzle();
  }

  function launchAngleRad() {
    return Number(angleInput.value) * Math.PI / 180;
  }

  function muzzlePosition() {
    const a = launchAngleRad();
    return {
      x: cannon.x + Math.cos(a) * cannon.barrelLength,
      y: cannon.y - Math.sin(a) * cannon.barrelLength
    };
  }

  function placeBallAtMuzzle() {
    const m = muzzlePosition();
    ball.x = m.x;
    ball.y = m.y;
    ball.vx = 0;
    ball.vy = 0;
  }

  function setStatus(text) {
    statusText.textContent = text;
  }

  function reset() {
    mode = 'idle';
    bounceCount = 0;
    stoppedAt = 0;
    muzzleFlash = 0;
    smoke = [];
    trail = [];
    ball.angle = 0;
    placeBallAtMuzzle();
    setStatus('待发射');
    updateHUD();
  }

  function fire() {
    const a = launchAngleRad();
    const speed = Number(speedInput.value);

    placeBallAtMuzzle();

    ball.vx = Math.cos(a) * speed;
    ball.vy = -Math.sin(a) * speed;

    mode = 'flying';
    bounceCount = 0;
    stoppedAt = 0;
    muzzleFlash = 0.12;
    trail = [];

    const m = muzzlePosition();
    for (let i = 0; i < 22; i++) {
      smoke.push({
        x: m.x + (Math.random() - .5) * 10,
        y: m.y + (Math.random() - .5) * 10,
        vx: 35 + Math.random() * 70,
        vy: -20 - Math.random() * 80,
        life: .5 + Math.random() * .7,
        size: 5 + Math.random() * 12
      });
    }

    setStatus('飞行中');
  }

  function update(dt, now) {
    if (muzzleFlash > 0) muzzleFlash -= dt;

    for (const p of smoke) {
      p.x += p.vx * dt;
      p.y += p.vy * dt;
      p.vx *= Math.pow(0.35, dt);
      p.vy -= 5 * dt;
      p.life -= dt;
      p.size += 7 * dt;
    }
    smoke = smoke.filter(p => p.life > 0);

    if (mode === 'flying') {
      // 半隐式欧拉积分
      ball.vy += physics.gravity * dt;

      const dragFactor = Math.exp(-physics.airDrag * dt);
      ball.vx *= dragFactor;
      ball.vy *= dragFactor;

      ball.x += ball.vx * dt;
      ball.y += ball.vy * dt;
      ball.angle += ball.vx * dt / ball.r;

      trail.push({ x: ball.x, y: ball.y, life: 1 });
      if (trail.length > 120) trail.shift();

      // 地面碰撞
      if (ball.y + ball.r >= groundY && ball.vy > 0) {
        ball.y = groundY - ball.r;

        const impactSpeed = ball.vy;
        bounceCount++;

        ball.vy = -ball.vy * physics.restitution;
        ball.vx *= physics.groundFriction;

        // 低能量反弹改为滚动
        if (impactSpeed < physics.bounceThreshold || Math.abs(ball.vy) < 35) {
          ball.vy = 0;
          mode = 'rolling';
          setStatus('滚动中');
        } else {
          setStatus(`第 ${bounceCount} 次反弹`);
        }
      }

      // 右侧越界后从视野外返回重置，防止永远跑丢
      if (ball.x - ball.r > W + 80) {
        mode = 'stopped';
        stoppedAt = now;
      }
    }

    if (mode === 'rolling') {
      ball.y = groundY - ball.r;

      if (Math.abs(ball.vx) > 0) {
        const sign = Math.sign(ball.vx);
        const next = Math.abs(ball.vx) - physics.rollingFriction * dt;
        ball.vx = sign * Math.max(0, next);

        ball.x += ball.vx * dt;
        ball.angle += ball.vx * dt / ball.r;
      }

      trail.push({ x: ball.x, y: ball.y, life: .55 });
      if (trail.length > 120) trail.shift();

      if (Math.abs(ball.vx) <= physics.stopSpeed) {
        ball.vx = 0;
        mode = 'stopped';
        stoppedAt = now;
        setStatus('已停止');
      }
    }

    if (mode === 'stopped' && now - stoppedAt > 1700) {
      reset();
    }

    for (const p of trail) p.life -= dt * .65;
    trail = trail.filter(p => p.life > 0);

    updateHUD();
  }

  function updateHUD() {
    vxText.textContent = ball.vx.toFixed(1);
    vyText.textContent = ball.vy.toFixed(1);
    bounceText.textContent = bounceCount;
  }

  function drawBackground() {
    // 天空
    const sky = ctx.createLinearGradient(0, 0, 0, groundY);
    sky.addColorStop(0, '#b9e8ff');
    sky.addColorStop(1, '#edfaff');
    ctx.fillStyle = sky;
    ctx.fillRect(0, 0, W, groundY);

    // 太阳
    ctx.beginPath();
    ctx.arc(W - 95, 78, 35, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255, 219, 92, .9)';
    ctx.fill();

    // 云
    drawCloud(W * .30, 92, 1);
    drawCloud(W * .62, 150, .78);

    // 远山
    ctx.beginPath();
    ctx.moveTo(0, groundY);
    for (let x = 0; x <= W; x += 60) {
      const y = groundY - 45 - Math.sin(x * .012) * 26 - Math.sin(x * .027) * 12;
      ctx.lineTo(x, y);
    }
    ctx.lineTo(W, groundY);
    ctx.closePath();
    ctx.fillStyle = '#a8d28d';
    ctx.fill();

    // 草地
    const grass = ctx.createLinearGradient(0, groundY, 0, H);
    grass.addColorStop(0, '#76b852');
    grass.addColorStop(1, '#4f8f37');
    ctx.fillStyle = grass;
    ctx.fillRect(0, groundY, W, H - groundY);

    // 地面线
    ctx.strokeStyle = '#426c32';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(0, groundY);
    ctx.lineTo(W, groundY);
    ctx.stroke();

    // 草纹
    ctx.strokeStyle = 'rgba(45, 100, 45, .28)';
    ctx.lineWidth = 1;
    for (let x = 10; x < W; x += 20) {
      ctx.beginPath();
      ctx.moveTo(x, groundY + 14);
      ctx.lineTo(x + 4, groundY + 6);
      ctx.moveTo(x + 4, groundY + 14);
      ctx.lineTo(x + 8, groundY + 5);
      ctx.stroke();
    }
  }

  function drawCloud(x, y, s) {
    ctx.fillStyle = 'rgba(255,255,255,.78)';
    ctx.beginPath();
    ctx.arc(x, y, 26*s, 0, Math.PI*2);
    ctx.arc(x+30*s, y-12*s, 34*s, 0, Math.PI*2);
    ctx.arc(x+68*s, y, 25*s, 0, Math.PI*2);
    ctx.arc(x+34*s, y+11*s, 31*s, 0, Math.PI*2);
    ctx.fill();
  }

  function drawTrajectoryGuide() {
    if (mode !== 'idle') return;

    const a = launchAngleRad();
    const speed = Number(speedInput.value);
    const m = muzzlePosition();

    const vx = Math.cos(a) * speed;
    const vy = -Math.sin(a) * speed;

    ctx.save();
    ctx.setLineDash([6, 8]);
    ctx.strokeStyle = 'rgba(15, 118, 110, .40)';
    ctx.lineWidth = 2;
    ctx.beginPath();

    for (let t = 0; t < 2.5; t += .035) {
      const x = m.x + vx * t;
      const y = m.y + vy * t + .5 * physics.gravity * t * t;
      if (x > W || y > groundY) break;
      if (t === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }

    ctx.stroke();
    ctx.restore();
  }

  function drawTrail() {
    if (trail.length < 2) return;

    ctx.save();
    ctx.lineCap = 'round';
    for (let i = 1; i < trail.length; i++) {
      const p0 = trail[i - 1];
      const p1 = trail[i];
      const alpha = Math.max(0, Math.min(1, p1.life)) * .36;
      ctx.strokeStyle = `rgba(245, 158, 11, ${alpha})`;
      ctx.lineWidth = 2 + alpha * 5;
      ctx.beginPath();
      ctx.moveTo(p0.x, p0.y);
      ctx.lineTo(p1.x, p1.y);
      ctx.stroke();
    }
    ctx.restore();
  }

  function drawCannon() {
    const a = launchAngleRad();

    ctx.save();

    // 炮架
    ctx.fillStyle = '#5b4636';
    ctx.fillRect(cannon.x - 44, cannon.y + 12, 90, 18);

    // 轮子
    for (const dx of [-30, 30]) {
      ctx.beginPath();
      ctx.arc(cannon.x + dx, cannon.y + 32, 24, 0, Math.PI * 2);
      ctx.fillStyle = '#3f3028';
      ctx.fill();

      ctx.beginPath();
      ctx.arc(cannon.x + dx, cannon.y + 32, 13, 0, Math.PI * 2);
      ctx.strokeStyle = '#9a7659';
      ctx.lineWidth = 4;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(cannon.x + dx, cannon.y + 32, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#b08a67';
      ctx.fill();
    }

    // 炮管
    ctx.translate(cannon.x, cannon.y);
    ctx.rotate(-a);

    const grad = ctx.createLinearGradient(0, -16, 0, 16);
    grad.addColorStop(0, '#64748b');
    grad.addColorStop(.5, '#1f2937');
    grad.addColorStop(1, '#0f172a');

    ctx.fillStyle = grad;
    roundRect(ctx, -16, -cannon.barrelWidth/2, cannon.barrelLength + 24, cannon.barrelWidth, 7);
    ctx.fill();

    // 炮口
    ctx.fillStyle = '#111827';
    roundRect(ctx, cannon.barrelLength - 5, -17, 20, 34, 5);
    ctx.fill();

    ctx.fillStyle = '#020617';
    ctx.fillRect(cannon.barrelLength + 5, -12, 6, 24);

    // 点火火焰
    if (muzzleFlash > 0) {
      ctx.beginPath();
      ctx.moveTo(cannon.barrelLength + 14, 0);
      ctx.lineTo(cannon.barrelLength + 48 + Math.random()*18, -16);
      ctx.lineTo(cannon.barrelLength + 35, 0);
      ctx.lineTo(cannon.barrelLength + 50 + Math.random()*20, 18);
      ctx.closePath();
      ctx.fillStyle = '#f97316';
      ctx.fill();

      ctx.beginPath();
      ctx.moveTo(cannon.barrelLength + 12, 0);
      ctx.lineTo(cannon.barrelLength + 39, -8);
      ctx.lineTo(cannon.barrelLength + 30, 0);
      ctx.lineTo(cannon.barrelLength + 40, 9);
      ctx.closePath();
      ctx.fillStyle = '#fde047';
      ctx.fill();
    }

    ctx.restore();

    // 炮身连接轴
    ctx.beginPath();
    ctx.arc(cannon.x, cannon.y, 23, 0, Math.PI * 2);
    ctx.fillStyle = '#334155';
    ctx.fill();

    ctx.beginPath();
    ctx.arc(cannon.x, cannon.y, 8, 0, Math.PI * 2);
    ctx.fillStyle = '#94a3b8';
    ctx.fill();
  }

  function drawSmoke() {
    for (const p of smoke) {
      const alpha = Math.max(0, Math.min(1, p.life)) * .35;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(71, 85, 105, ${alpha})`;
      ctx.fill();
    }
  }

  function drawBall() {
    ctx.save();
    ctx.translate(ball.x, ball.y);
    ctx.rotate(ball.angle);

    // 阴影
    const shadowDist = Math.max(0, groundY - (ball.y + ball.r));
    const shadowAlpha = Math.max(.06, .22 - shadowDist / 1100);
    ctx.save();
    ctx.rotate(-ball.angle);
    ctx.translate(0, shadowDist + ball.r + 5);
    ctx.scale(1.5, .35);
    ctx.beginPath();
    ctx.arc(0, 0, ball.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(15,23,42,${shadowAlpha})`;
    ctx.fill();
    ctx.restore();

    // 球体
    const grad = ctx.createRadialGradient(-5, -7, 2, 0, 0, ball.r + 2);
    grad.addColorStop(0, '#fff7ae');
    grad.addColorStop(.22, '#facc15');
    grad.addColorStop(.7, '#f59e0b');
    grad.addColorStop(1, '#b45309');

    ctx.beginPath();
    ctx.arc(0, 0, ball.r, 0, Math.PI * 2);
    ctx.fillStyle = grad;
    ctx.fill();

    // 旋转标记
    ctx.strokeStyle = 'rgba(120,53,15,.72)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(-ball.r * .6, 0);
    ctx.lineTo(ball.r * .6, 0);
    ctx.moveTo(0, -ball.r * .6);
    ctx.lineTo(0, ball.r * .6);
    ctx.stroke();

    ctx.restore();
  }

  function roundRect(c, x, y, w, h, r) {
    const rr = Math.min(r, w/2, h/2);
    c.beginPath();
    c.moveTo(x + rr, y);
    c.arcTo(x + w, y, x + w, y + h, rr);
    c.arcTo(x + w, y + h, x, y + h, rr);
    c.arcTo(x, y + h, x, y, rr);
    c.arcTo(x, y, x + w, y, rr);
    c.closePath();
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    drawBackground();
    drawTrajectoryGuide();
    drawTrail();
    drawCannon();
    drawSmoke();
    drawBall();
  }

  function loop(now) {
    let dt = (now - lastTime) / 1000;
    lastTime = now;

    // 防止标签页切回后出现超大时间步
    dt = Math.min(dt, 1 / 30);

    // 分步积分，提升高速撞地稳定性
    const steps = Math.max(1, Math.ceil(dt / (1 / 120)));
    const subDt = dt / steps;

    for (let i = 0; i < steps; i++) {
      update(subDt, now);
    }

    draw();
    requestAnimationFrame(loop);
  }

  angleInput.addEventListener('input', () => {
    angleValue.textContent = `${angleInput.value}°`;
    if (mode === 'idle') placeBallAtMuzzle();
  });

  speedInput.addEventListener('input', () => {
    speedValue.textContent = speedInput.value;
  });

  fireBtn.addEventListener('click', fire);
  resetBtn.addEventListener('click', reset);

  window.addEventListener('resize', resize);

  resize();
  reset();
  requestAnimationFrame(loop);
})();
</script>
</body>
</html>
'''

path = Path("/mnt/data/cannon_projectile_animation.html")
path.write_text(html, encoding="utf-8")
print(f"已创建: {path}")
